# Docker Compose — PostgreSQL container credentials
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel

# Database connections
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@db:5432/sentinel
DATABASE_SYNC_URL=postgresql://sentinel:sentinel@db:5432/sentinel

# JWT
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Allowed CORS origins, comma-separated
BACKEND_CORS_ORIGINS=http://localhost:3000

# LLM provider (OpenAI-compatible)
LLM_API_KEY=
LLM_MODEL=openai/gpt-4.1-nano
LLM_REBALANCE_MODEL=            # falls back to LLM_MODEL if not set
LLM_BASE_URL=
LLM_HISTORY_LIMIT=20
LLM_VISION_ENABLED=true

# Email (SMTP)
# For development use Mailtrap: https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@sentinel.app
EMAILS_FROM_NAME=Sentinel

# Auth flow
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

# Frontend base URL (used in email links)
FRONTEND_URL=http://localhost:3000

# File storage (Cloudflare R2 or any S3-compatible provider)
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_ENDPOINT_URL=        # https://<account_id>.r2.cloudflarestorage.com
S3_PUBLIC_URL=          # https://pub-xxx.r2.dev
